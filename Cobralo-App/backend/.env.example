# Servidor de Producción (Express + Prisma)
PORT=3000
NODE_ENV=production

# Seguridad
# Genera uno nuevo en producción con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_new_secure_jwt_secret_here

# Base de Datos (SQLite para este demo, en PRO se recomienda PostgreSQL/MySQL)
DATABASE_URL="file:./prisma/dev.db"

# Orígenes Permitidos (CORS)
FRONTEND_URL="https://cobraloapp.com"
LANDING_URL="https://cobralo.info"

# Notificaciones (Requerido para PRO features)
# Obtén tu API Key en resend.com
RESEND_API_KEY=re_your_api_key_here

# WhatsApp (Meta Cloud API)
WHATSAPP_TOKEN=your_token_here
WHATSAPP_PHONE_NUMBER_ID=your_id_here
