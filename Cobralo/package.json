{
  "name": "cobralo-workspace",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend",
    "install-all": "npm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
